{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "moemail-api-worker",
  "main": "workers/api.ts",
  "compatibility_date": "2024-03-20",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "routes": [
    {
      "pattern": "mail.zzboy.tk/api/*",
      "zone_name": "zzboy.tk"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "migrations_dir": "drizzle",
      "database_name": "moemail-db",
      "database_id": "3a6cf9aa-0dd1-438e-bd73-6212c8c28dfe"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "SITE_CONFIG",
      "id": "ea86e5cbef424776867493573b909824"
    }
  ]
}
